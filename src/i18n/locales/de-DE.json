  "gym": {
    "name": "Rechtschreib-Arena",
    "notReady": "Du bist noch nicht bereit für mich! Besiege alle Trainer und beherrsche zuerst jedes Wort in diesem Bereich!"
  },
  "npc": {
    "mom": {
      "name": "Mama",
      "dialog": [
        "Pass da draußen auf dich auf, mein Kind!",
        "Denk daran, das Spelling-Center zu besuchen, wenn deine Spellingmon müde sind."
      ]
    },
    "healer": {
      "name": "Schwester Lexi",
      "dialog": "Willkommen im Rechtschreibzentrum! Lass mich deine Spellingmon heilen."
    },
    "gym_boss": {
      "1": {
        "name": "Arthur Alphabet",
        "intro": "A steht für Action! B für Battle! Zeig mir, ob du dein ABC beherrschst!",
        "defeat": "Z steht für... Zero Chance! Du hast das Alphabet gemeistert!"
      },
      "2": {
        "name": "Blenda Boulevard",
        "intro": "Ich mixe dein Team zu einem Smoothie der Niederlage! Nur saubere Rechtschreibung zählt!",
        "defeat": "Du hast deine Wörter perfekt gemixt. Ein glatter Sieg!"
      },
      "3": {
        "name": "Silas Syllable",
        "intro": "Eins, zwei, drei! Zähl den Takt, fühl den Rhythmus des Duells!",
        "defeat": "Dein Rhythmus war überlegen. Du hast keinen Schlag ausgelassen!"
      },
      "4": {
        "name": "Sophie Suffix",
        "intro": "Ich hänge 'besiegt' an das Ende deines Namens! Wie gefällt dir dieser Suffix?",
        "defeat": "Ich schätze, ich bin diejenige, die jetzt 'fertig' ist. Gute Arbeit!"
      },
      "5": {
        "name": "Preston Prefix",
        "intro": "Ich habe immer das erste Wort! Bereite dich darauf vor, überholt zu werden!",
        "defeat": "Diesen Ausgang habe ich nicht vorhergesehen. Du hast meinen Sieg ver-hindert!"
      },
      "6": {
        "name": "Homer Homophone",
        "intro": "Du wirst sehen, dass ich hier der Meer-König bin! Oder ist es 'mehr'? Du wirst es bald wissen!",
        "defeat": "Ich wusste, ich hätte am Meer bleiben sollen... oder war es 'mehr'? Du bist zu gut!"
      },
      "7": {
        "name": "Lana Loanword",
        "intro": "Ich habe Techniken aus der ganzen Welt geliehen. Kannst du mit meinem internationalen Flair mithalten?",
        "defeat": "Dein Wortschatz ist wirklich international. Merci für den Kampf!"
      },
      "8": {
        "name": "Phona Phoneme",
        "intro": "Jeder Laut zählt! Wenn du eine einzige Note verpasst, ist es vorbei!",
        "defeat": "Das klang nach einem Sieg für dich. Deine Rechtschreibung ist absolut stimmig!"
      },
      "9": {
        "name": "Malphas der Stumme",
        "intro": "Der Stumme Sturm ist meine Schöpfung! Wenn das Lexikon gelöscht ist, werde ich der Einzige mit einer Stimme sein!",
        "defeat": "Meine Stille... wurde gebrochen. Die Worte... sie kehren zurück. Der Sturm ist vorbei."
      },
      "name": "Arenaleiter",
      "intro": "Du beherrschst also die Landessprache? Mal sehen, ob du dich zum Sieg buchstabieren kannst!",
      "defeat": "Beeindruckend! Du hast wirklich ein Händchen für Worte. Hier ist dein Orden!"
    },
    "rival": {
      "name": "Rivale Robin",
      "dialog": "Ich werde der beste Lexika-Scout aller Zeiten sein und Spellinghome retten, indem ich jedes Wort zuerst beherrsche! En garde!",
      "victory": "Worte sind Macht, und dir sind sie ausgegangen!",
      "defeat": "Nicht schlecht! Aber glaub nicht, dass du schon gewonnen hast. Ich werde derjenige sein, der jedes Wort zuerst beherrscht!",
      "mercy": "Keine Sorge, du wirst besser werden! Ich mache mich auf den Weg, um Spellinghome zu retten!"
    }
  },
