  "gym": {
    "name": "Gimnasio de Ortografía",
    "notReady": "¡Aún no estás listo para mí! ¡Derrota a todos los entrenadores y domina cada palabra de esta zona primero!"
  },
  "npc": {
    "mom": {
      "name": "Mamá",
      "dialog": [
        "¡Ten cuidado ahí fuera, cielo!",
        "Recuerda visitar el Centro de Ortografía si tus Spellingmon están cansados."
      ]
    },
    "healer": {
      "name": "Enfermera Lexi",
      "dialog": "¡Bienvenido al Centro de Ortografía! Déjame curar a tus Spellingmon."
    },
    "gym_boss": {
      "1": {
        "name": "Arturo Alfabeto",
        "intro": "¡A de Acción! ¡B de Batalla! ¡Veamos si conoces el abecedario!",
        "defeat": "¡Z de... Zero posibilidades de perder, creí! ¡Has dominado el Alfabeto!"
      },
      "2": {
        "name": "Berta Bulevar",
        "intro": "¡Mezclaré a tu equipo en un batido de derrota! ¡Solo ortografía fluida!",
        "defeat": "Mezclaste tus palabras perfectamente. ¡Una victoria muy fluida!"
      },
      "3": {
        "name": "Silvio Sílaba",
        "intro": "¡Uno, dos, tres! ¡Cuenta los pulsos, siente el ritmo del duelo!",
        "defeat": "Tu ritmo fue superior. ¡No saltaste ni una sílaba!"
      },
      "4": {
        "name": "Sofía Sufijo",
        "intro": "¡Añadiré 'derrotado' al final de tu nombre! ¿Qué te parece ese sufijo?",
        "defeat": "Supongo que soy yo la que ha 'terminado' ahora. ¡Buen trabajo!"
      },
      "5": {
        "name": "Pedro Prefijo",
        "intro": "¡Yo siempre tengo la primera palabra! ¡Prepárate para ser anticipado!",
        "defeat": "No preví este resultado. ¡Pre-veniste mi victoria!"
      },
      "6": {
        "name": "Homero Homófono",
        "intro": "¡Verás que soy el rey de los bienes! ¿O era 'vienes'? ¡Lo sabrás pronto!",
        "defeat": "Sabía que debía haberme quedado en la cima... ¿o era 'cima'? ¡Eres muy bueno!"
      },
      "7": {
        "name": "Lara Extranjerismo",
        "intro": "He tomado prestadas técnicas de todo el mundo. ¿Puedes seguir mi estilo extranjero?",
        "defeat": "Tu vocabulario es verdaderamente internacional. ¡Merci por la batalla!"
      },
      "8": {
        "name": "Fona Fonema",
        "intro": "¡Cada sonido importa! ¡Si fallas una sola nota, se acabó el juego!",
        "defeat": "Sonó como una victoria para ti. ¡Tu ortografía es perfecta!"
      },
      "9": {
        "name": "Malfas el Mudo",
        "intro": "¡La Tormenta Silenciosa es mi creación! ¡Con el Léxico borrado, seré el único con voz!",
        "defeat": "Mi silencio... se ha roto. Las palabras... están volviendo. La tormenta ha terminado."
      },
      "name": "Líder de Gimnasio",
      "intro": "¿Así que has dominado el idioma local? ¡Veamos si puedes deletrear tu camino a la victoria!",
      "defeat": "¡Impresionante! Realmente tienes un don con las palabras. ¡Aquí tienes tu medalla!"
    },
    "rival": {
      "name": "Rival Robin",
      "dialog": "¡Voy a ser el mejor explorador de léxico y salvaré Spellinghome dominando cada palabra primero! ¡En guardia!",
      "victory": "¡Las palabras son poder, y te has quedado sin ellas!",
      "defeat": "¡Nada mal! Pero no creas que ya ganaste. ¡Yo seré quien domine cada palabra primero!",
      "mercy": "¡No te preocupes, mejorarás! ¡Me voy a salvar Spellinghome!"
    }
  },
