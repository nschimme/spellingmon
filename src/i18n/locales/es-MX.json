      "intro_3": "¿Puedes definir 'derrota'?",
      "intro_4": "¡Tu sintaxis está llena de errores!",
      "intro_5": "He estado estudiando esta ruta por semanas.",
      "defeat_1": "Necesito revisar los libros...",
      "defeat_2": "¡Me corregiste!",
