  "npc": {
    "mom": {
      "name": "Mom",
      "dialog": [
        "Be careful out there, dear!",
        "Remember to visit the Spelling Center if your Spellingmon are tired."
      ]
    },
    "healer": {
      "name": "Nurse Lexi",
      "dialog": "Welcome to the Spelling Center! Let me heal your Spellingmon."
    },
    "gym_boss": {
      "name": "Gym Master",
      "intro": "So, you've mastered the local tongue? Let's see if you can spell your way to a victory!",
      "defeat": "Impressive! You truly have a way with words. Here is your badge!",
      "1": {
        "name": "Arthur Alphabet",
        "intro": "A is for Action! B is for Battle! Let's see if you know your ABCs!",
        "defeat": "Z is for... Zero chance I thought I'd lose! You've mastered the Alphabet!"
      },
      "2": {
        "name": "Blenda Boulevard",
        "intro": "I'll blend your team into a smoothie of defeat! Smooth spelling only!",
        "defeat": "You blended your words perfectly. A smooth victory indeed!"
      },
      "3": {
        "name": "Silas Syllable",
        "intro": "One, two, three! Count the beats, feel the rhythm of the duel!",
        "defeat": "Your rhythm was superior. You didn't skip a single beat!"
      },
      "4": {
        "name": "Sophie Suffix",
        "intro": "I'll add 'defeated' to the end of your name! How's that for a suffix?",
        "defeat": "I guess I'm the one who's 'finished' now. Great job!"
      },
      "5": {
        "name": "Preston Prefix",
        "intro": "I always have the first word! Prepare to be pre-empted!",
        "defeat": "I didn't foresee this outcome. You pre-vented my victory!"
      },
      "6": {
        "name": "Homer Homophone",
        "intro": "You'll see that I'm the sea king here! Or is it 'see'? You'll know soon enough!",
        "defeat": "I knew I should have stayed at sea... or is it 'see'? You're too good!"
      },
      "7": {
        "name": "Lana Loanword",
        "intro": "I've borrowed techniques from all over the world. Can you keep up with my foreign flair?",
        "defeat": "Your vocabulary is truly international. Merci for the battle!"
      },
      "8": {
        "name": "Phona Phoneme",
        "intro": "Every sound matters! If you miss a single note, it's game over!",
        "defeat": "Sounded like a victory for you. Your spelling is pitch-perfect!"
      },
      "9": {
        "name": "Malphas the Muted",
        "intro": "The Silent Storm is my creation! With the Lexicon erased, I shall be the only one with a voice!",
        "defeat": "My silence... has been broken. The words... they are returning. The storm is over."
      }
    },
    "rival": {
      "name": "Rival Robin",
      "dialog": "I'm going to be the best Lexicon Scout ever and save Spellinghome by mastering every word first! En garde!",
      "victory": "Words are power, and you have run out of them!",
      "defeat": "Not bad! But don't think you've won yet. I'll be the one to master every word first!",
      "mercy": "Don't worry, you'll get better! I'm off to save Spellinghome!"
    }
  },
